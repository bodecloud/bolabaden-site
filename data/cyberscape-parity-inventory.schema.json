{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bolabaden.org/schemas/cyberscape-parity-inventory.schema.json",
  "title": "Cyberscape parity inventory",
  "type": "object",
  "required": ["version", "statusValues", "evidenceLabels", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "statusValues": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidenceLabels": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": [
        "id",
        "category",
        "baselineCapability",
        "cyberscapeTarget",
        "status",
        "evidence",
        "proof",
        "nextAction"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "category": {
          "type": "string"
        },
        "baselineCapability": {
          "type": "string"
        },
        "cyberscapeTarget": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "proof": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "nextAction": {
          "type": "string"
        }
      }
    }
  }
}
