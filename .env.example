# bolabaden-site — environment template
# Copy to .env.local and change only what you need. All NEXT_PUBLIC_* vars have safe defaults.

# --- Site identity ---
# NEXT_PUBLIC_OWNER_NAME=Boden Crouch
# NEXT_PUBLIC_JOB_TITLE=Infrastructure Engineer
# NEXT_PUBLIC_JOB_SUBTITLE=Self-taught infrastructure engineer & software developer
# NEXT_PUBLIC_BIO=...
# NEXT_PUBLIC_CONTACT_EMAIL=boden.crouch@gmail.com
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/boden-crouch-555897193/

# --- Domain & URLs ---
# NEXT_PUBLIC_SITE_PROTOCOL=https
# NEXT_PUBLIC_SITE_DOMAIN=bolabaden.org
# NEXT_PUBLIC_SITE_URL=https://bolabaden.org
# NEXT_PUBLIC_SITE_NAME=bolabaden.org
# NEXT_PUBLIC_HTML_LANG=en
# NEXT_PUBLIC_SITE_SECTION_LABEL=Independent Web Hub
# NEXT_PUBLIC_SITE_META_DESCRIPTION=...
# NEXT_PUBLIC_RESUME_PATH=/Boden_Crouch_Resume.pdf

# --- GitHub (server + public) ---
# GITHUB_TOKEN=ghp_...   # optional; raises API rate limits for /projects
# NEXT_PUBLIC_GITHUB_OWNER=bolabaden
# NEXT_PUBLIC_GITHUB_USERS=bolabaden,th3w1zard1

# --- Search (SearXNG) ---
# NEXT_PUBLIC_SEARXNG_URL=https://your-searx.example
# NEXT_PUBLIC_SEARXNG_PUBLIC_URL=https://searx.be
# NEXT_PUBLIC_SEARXNG_SEARCH_PATH=/search
# NEXT_PUBLIC_SEARXNG_FALLBACK_ENABLED=true
# SEARXNG_FALLBACK_ENABLED=true
# NEXT_PUBLIC_SEARCH_PAGE_TITLE=Search
# NEXT_PUBLIC_SEARCH_PAGE_DESCRIPTION=Search the web with SearXNG without leaving bolabaden.org.

# --- Chrome mode ---
# NEXT_PUBLIC_CHROME_MODE=dual
# dual = portfolio chrome on /about (default); discovery = PageLayout on /about too

# --- Home release feed ---
# NEXT_PUBLIC_HOME_FUTURE_RELEASES_ENABLED=true

# --- Home page builder (JSON arrays — see README for shapes) ---
# NEXT_PUBLIC_HOME_LAYOUT_SECTIONS_JSON=[{"id":"showcase","label":"Showcase","enabled":true,"order":1},...]
# NEXT_PUBLIC_HOME_EMBEDS_MODE=default
# NEXT_PUBLIC_HOME_HUB_CARDS_JSON=[...]
# NEXT_PUBLIC_HOME_EXPLORE_LANES_JSON=[...]
# NEXT_PUBLIC_HOME_FUTURE_PLACEHOLDERS_JSON=[...]
# NEXT_PUBLIC_HOME_SHOWCASE_ITEMS_JSON=[...]

# --- About page builder ---
# NEXT_PUBLIC_ABOUT_LAYOUT_SECTIONS_JSON=[...]
# NEXT_PUBLIC_ABOUT_EMBEDS_MODE=default

# --- Navigation ---
# NEXT_PUBLIC_NAV_ITEMS_JSON=[{"href":"/projects","label":"Contributions"},...]

# --- Page copy (discovery routes) ---
# NEXT_PUBLIC_CONTACT_HERO_TITLE=Get in touch
# NEXT_PUBLIC_PROJECTS_PAGE_TITLE=Projects
# NEXT_PUBLIC_PROJECTS_PAGE_DESCRIPTION=Open-source contributions, repository activity, and public code artifacts.

# --- Dashboard ---
# NEXT_PUBLIC_DASHBOARD_PAGE_TITLE=Dashboard — Status & Monitoring
# NEXT_PUBLIC_DASHBOARD_EMBEDS_ENABLED=true

# --- Embeds & live services ---
# NEXT_PUBLIC_EMBED_SERVICES_JSON=[...]

# --- Fallback content (offline / no API) ---
# NEXT_PUBLIC_FALLBACK_PROJECTS_JSON=[...]
# NEXT_PUBLIC_TECH_STACK_JSON=[...]
# NEXT_PUBLIC_CONTACT_INFO_JSON=[...]

# --- Guides (server) ---
# GUIDES_DIR=/app/guides

# --- Docker / infra (server, production) ---
# DOCKER_PROXY_URL=http://dockerproxy:2375
# PROMETHEUS_URL=http://prometheus:9090
# DOMAIN=bolabaden.org

# --- Build / deploy ---
# DEPLOY_TARGET=github-pages
# NEXT_PUBLIC_PAGES_BASE_PATH=/home
# NEXT_PUBLIC_STATIC_EXPORT=false
# Set automatically to true when DEPLOY_TARGET=github-pages (see next.config.ts)
